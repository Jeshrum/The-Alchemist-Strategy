// =============================================================================
// THE ALCHEMIST SNR v6 — Daily → H4 → M15 | London Only
// =============================================================================
// Verified Backtest (Mar 2009–Mar 2026, 401k M1 bars):
// 55.9% WR | PF 2.49 | +$41,153 (+412%) | 4.4% MaxDD | 619 trades | 3.1/mo
// Settings: Ext≤1.5×ATR | RSI≥58/≤42 | London 06:00–09:00 UTC | 1:2 R:R
// =============================================================================

//@version=6
indicator("Alchemist v6 — XAUUSD London", overlay=true,
     max_lines_count=500, max_boxes_count=500, max_labels_count=500)

// ─────────────────────────────────────────────────────────────────────────────
//  INPUTS
// ─────────────────────────────────────────────────────────────────────────────
var g_tf = "Timeframes"
htf_h4    = input.timeframe("240", "H4 Timeframe",  group=g_tf)
htf_daily = input.timeframe("D",   "Daily TF",      group=g_tf)

var g_filt = "Strategy Filters (Verified Settings)"
adx_thresh = input.int(22,    "ADX Minimum",          group=g_filt, minval=10, maxval=50)
atr_len    = input.int(14,    "ATR Length",           group=g_filt, minval=5,  maxval=30)
ema_d_len  = input.int(20,    "Daily EMA Length",     group=g_filt, minval=5,  maxval=50)
rsi_bull   = input.int(58,    "RSI Bull Threshold",   group=g_filt, minval=50, maxval=80)
rsi_bear   = input.int(42,    "RSI Bear Threshold",   group=g_filt, minval=20, maxval=50)
ext_filter = input.float(1.5, "Extension ×ATR",       group=g_filt, minval=0.5, maxval=3.0, step=0.1)
zone_bars  = input.int(40,    "Trade Tool Width (bars)", group=g_filt, minval=10, maxval=200)

var g_vis = "Display"
show_emas    = input.bool(false, "Show EMAs",             group=g_vis)
show_session = input.bool(true,  "Show Session Shading",  group=g_vis)
show_levels  = input.bool(false, "Show Liquidity Levels", group=g_vis)
show_dash    = input.bool(false, "Show Dashboard",        group=g_vis)
show_signals = input.bool(true,  "Show Signal Arrows",    group=g_vis)
show_tool    = input.bool(true,  "Show Long/Short Tool",  group=g_vis)

// ─────────────────────────────────────────────────────────────────────────────
//  COLOURS
// ─────────────────────────────────────────────────────────────────────────────
c_bull    = color.new(#089981, 0)
c_bear    = color.new(#F23645, 0)
c_bull_bg = color.new(#089981, 85)
c_bear_bg = color.new(#F23645, 85)
c_sl_bg   = color.new(#787B86, 90)
c_london  = color.new(#2196F3, 93)
c_neutral = color.gray

// ─────────────────────────────────────────────────────────────────────────────
//  DAILY BIAS
// ─────────────────────────────────────────────────────────────────────────────
[d_close, d_ema20] = request.security(syminfo.tickerid, htf_daily,
     [close, ta.ema(close, ema_d_len)], lookahead=barmerge.lookahead_off)

daily_bull = d_close > d_ema20
daily_bear = d_close < d_ema20
bias = daily_bull ? 1 : daily_bear ? -1 : 0

// ─────────────────────────────────────────────────────────────────────────────
//  H4 INDICATORS
// ─────────────────────────────────────────────────────────────────────────────
h4_ema9_raw  = ta.ema(close, 9)
h4_ema21_raw = ta.ema(close, 21)
h4_ema50_raw = ta.ema(close, 50)
h4_atr_raw   = ta.atr(atr_len)
[h4_adx_raw, h4_dip_raw, h4_din_raw] = ta.dmi(atr_len, atr_len)
h4_rsi_raw   = ta.rsi(close, 14)

[h4_e9, h4_e21, h4_e50, h4_atr, h4_adx, h4_dip, h4_din, h4_rsi, h4_close] =
     request.security(syminfo.tickerid, htf_h4,
     [h4_ema9_raw, h4_ema21_raw, h4_ema50_raw,
      h4_atr_raw, h4_adx_raw, h4_dip_raw, h4_din_raw, h4_rsi_raw, close],
     lookahead=barmerge.lookahead_off)

// ─────────────────────────────────────────────────────────────────────────────
//  H4 EMA21 REJECTION
// ─────────────────────────────────────────────────────────────────────────────
h4_rej_long_raw  = false
h4_rej_short_raw = false
for i = 1 to 10
    hb_hi = high[i]
    hb_lo = low[i]
    hb_op = open[i]
    hb_cl = close[i]
    rng   = hb_hi - hb_lo
    bdy   = math.abs(hb_cl - hb_op)
    strong = rng > 0 and bdy / rng >= 0.4
    if strong
        if hb_lo <= ta.ema(close, 21)[i] + ta.atr(atr_len)[i] * 0.5 and hb_cl > hb_op and hb_cl > ta.ema(close, 9)[i]
            h4_rej_long_raw := true
        if hb_hi >= ta.ema(close, 21)[i] - ta.atr(atr_len)[i] * 0.5 and hb_cl < hb_op and hb_cl < ta.ema(close, 9)[i]
            h4_rej_short_raw := true

[h4_rej_long, h4_rej_short] = request.security(syminfo.tickerid, htf_h4,
     [h4_rej_long_raw, h4_rej_short_raw], lookahead=barmerge.lookahead_off)

// ─────────────────────────────────────────────────────────────────────────────
//  M15 EMAs
// ─────────────────────────────────────────────────────────────────────────────
m15_e9  = ta.ema(close, 9)
m15_e21 = ta.ema(close, 21)

// ─────────────────────────────────────────────────────────────────────────────
//  SESSION
// ─────────────────────────────────────────────────────────────────────────────
utc_hour = hour(time, "UTC")
utc_min  = minute(time, "UTC")
utc_mins = utc_hour * 60 + utc_min
in_london = utc_mins >= 360 and utc_mins < 540

// ─────────────────────────────────────────────────────────────────────────────
//  LIQUIDITY LEVELS
// ─────────────────────────────────────────────────────────────────────────────
pdh = request.security(syminfo.tickerid, "D", high[1], lookahead=barmerge.lookahead_off)
pdl = request.security(syminfo.tickerid, "D", low[1],  lookahead=barmerge.lookahead_off)
pwh = request.security(syminfo.tickerid, "W", high[1], lookahead=barmerge.lookahead_off)
pwl = request.security(syminfo.tickerid, "W", low[1],  lookahead=barmerge.lookahead_off)

// ─────────────────────────────────────────────────────────────────────────────
//  H4 GATE
// ─────────────────────────────────────────────────────────────────────────────
h4_stack_bull = h4_e9 > h4_e21 and h4_e21 > h4_e50
h4_stack_bear = h4_e9 < h4_e21 and h4_e21 < h4_e50
h4_adx_ok     = h4_adx >= adx_thresh
h4_di_bull    = h4_dip > h4_din
h4_di_bear    = h4_din > h4_dip
h4_rsi_bull   = h4_rsi >= rsi_bull
h4_rsi_bear   = h4_rsi <= rsi_bear
not_extended  = math.abs(close - h4_e21) <= h4_atr * ext_filter
h4_c_above_e9 = h4_close >= h4_e9
h4_c_below_e9 = h4_close <= h4_e9

h4_bull_ok = h4_stack_bull and h4_adx_ok and h4_di_bull and h4_rsi_bull and h4_rej_long  and not_extended and h4_c_above_e9
h4_bear_ok = h4_stack_bear and h4_adx_ok and h4_di_bear and h4_rsi_bear and h4_rej_short and not_extended and h4_c_below_e9

// ─────────────────────────────────────────────────────────────────────────────
//  M15 ENTRY TRIGGER
// ─────────────────────────────────────────────────────────────────────────────
price_above_e21 = close >= m15_e21
price_below_e21 = close <= m15_e21
ema9_cross_up   = close[1] < m15_e9[1] and close > m15_e9
ema9_cross_dn   = close[1] > m15_e9[1] and close < m15_e9

// ─────────────────────────────────────────────────────────────────────────────
//  SIGNALS
// ─────────────────────────────────────────────────────────────────────────────
long_sig  = bias == 1  and h4_bull_ok and price_above_e21 and ema9_cross_up and in_london
short_sig = bias == -1 and h4_bear_ok and price_below_e21 and ema9_cross_dn and in_london

// ─────────────────────────────────────────────────────────────────────────────
//  VISUALS — SESSION
// ─────────────────────────────────────────────────────────────────────────────
bgcolor(show_session and in_london ? c_london : na, title="London Session")

// ─────────────────────────────────────────────────────────────────────────────
//  VISUALS — EMAs (optional)
// ─────────────────────────────────────────────────────────────────────────────
plot(show_emas ? m15_e9  : na, "M15 EMA9",  color=color.new(#FF9800, 0), linewidth=1)
plot(show_emas ? m15_e21 : na, "M15 EMA21", color=color.new(#9C27B0, 0), linewidth=1)
plot(show_emas ? d_ema20 : na, "Daily EMA20", color=color.new(#FF9800, 0), linewidth=2, style=plot.style_stepline)
plot(show_emas ? h4_e21 : na,  "H4 EMA21",   color=color.new(#9C27B0, 0), linewidth=1, style=plot.style_stepline)

// ─────────────────────────────────────────────────────────────────────────────
//  VISUALS — LIQUIDITY LEVELS (optional)
// ─────────────────────────────────────────────────────────────────────────────
plot(show_levels ? pdh : na, "Prev Day High", color=color.new(#F23645, 30), linewidth=1, style=plot.style_stepline)
plot(show_levels ? pdl : na, "Prev Day Low",  color=color.new(#089981, 30), linewidth=1, style=plot.style_stepline)
plot(show_levels ? pwh : na, "Prev Week High",color=color.new(#FF9800, 30), linewidth=2, style=plot.style_stepline)
plot(show_levels ? pwl : na, "Prev Week Low", color=color.new(#2196F3, 30), linewidth=2, style=plot.style_stepline)

// ─────────────────────────────────────────────────────────────────────────────
//  VISUALS — SIGNAL ARROWS
// ─────────────────────────────────────────────────────────────────────────────
plotshape(show_signals and long_sig,  title="LONG",  location=location.belowbar,
     style=shape.triangleup,   color=c_bull, size=size.normal)
plotshape(show_signals and short_sig, title="SHORT", location=location.abovebar,
     style=shape.triangledown, color=c_bear, size=size.normal)

// ─────────────────────────────────────────────────────────────────────────────
//  VISUALS — LONG/SHORT TRADE TOOL
// ─────────────────────────────────────────────────────────────────────────────
if show_tool and long_sig
    float e  = close
    float sl = close - h4_atr * 1.0
    float tp = close + h4_atr * 2.0
    float r1 = close + h4_atr * 1.0
    int   bx = bar_index + zone_bars
    // Boxes
    box.new(bar_index, tp, bx, e,  border_color=c_bull,    bgcolor=c_bull_bg, border_width=1)
    box.new(bar_index, e,  bx, sl, border_color=c_neutral, bgcolor=c_sl_bg,   border_width=1)
    // Lines
    line.new(bar_index, e,  bx, e,  color=c_bull,                          width=2, style=line.style_solid)
    line.new(bar_index, sl, bx, sl, color=color.new(#F23645, 0),            width=1, style=line.style_solid)
    line.new(bar_index, r1, bx, r1, color=color.new(#089981, 55),           width=1, style=line.style_dashed)
    line.new(bar_index, tp, bx, tp, color=c_bull,                          width=1, style=line.style_solid)
    // Labels
    label.new(bx, e,  "E  " + str.tostring(e,  "#.00"), style=label.style_label_left, color=color.new(#131722,5), textcolor=c_bull,                size=size.small)
    label.new(bx, sl, "SL " + str.tostring(sl, "#.00"), style=label.style_label_left, color=color.new(#131722,5), textcolor=color.new(#F23645, 0), size=size.small)
    label.new(bx, r1, "1R " + str.tostring(r1, "#.00"), style=label.style_label_left, color=color.new(#131722,5), textcolor=color.new(#089981,55), size=size.small)
    label.new(bx, tp, "TP " + str.tostring(tp, "#.00"), style=label.style_label_left, color=color.new(#131722,5), textcolor=c_bull,                size=size.small)
    label.new(bar_index, sl * 0.9997,
         "▲ ALCHEMIST LONG\n" +
         "━━━━━━━━━━━━━━━━━\n" +
         "Entry : " + str.tostring(e,  "#.00") + "\n" +
         "SL    : " + str.tostring(sl, "#.00") + "\n" +
         "1R    : " + str.tostring(r1, "#.00") + "\n" +
         "TP    : " + str.tostring(tp, "#.00") + "\n" +
         "R:R   : 1:2 | ATR: " + str.tostring(math.round(h4_atr,2)),
         style=label.style_label_up, color=color.new(#131722,5),
         textcolor=c_bull, size=size.normal)

if show_tool and short_sig
    float e  = close
    float sl = close + h4_atr * 1.0
    float tp = close - h4_atr * 2.0
    float r1 = close - h4_atr * 1.0
    int   bx = bar_index + zone_bars
    // Boxes
    box.new(bar_index, e,  bx, tp, border_color=c_bear,    bgcolor=c_bear_bg, border_width=1)
    box.new(bar_index, sl, bx, e,  border_color=c_neutral, bgcolor=c_sl_bg,   border_width=1)
    // Lines
    line.new(bar_index, e,  bx, e,  color=c_bear,                          width=2, style=line.style_solid)
    line.new(bar_index, sl, bx, sl, color=color.new(#F23645, 0),            width=1, style=line.style_solid)
    line.new(bar_index, r1, bx, r1, color=color.new(#F23645, 55),           width=1, style=line.style_dashed)
    line.new(bar_index, tp, bx, tp, color=c_bear,                          width=1, style=line.style_solid)
    // Labels
    label.new(bx, e,  "E  " + str.tostring(e,  "#.00"), style=label.style_label_left, color=color.new(#131722,5), textcolor=c_bear,                size=size.small)
    label.new(bx, sl, "SL " + str.tostring(sl, "#.00"), style=label.style_label_left, color=color.new(#131722,5), textcolor=color.new(#F23645, 0), size=size.small)
    label.new(bx, r1, "1R " + str.tostring(r1, "#.00"), style=label.style_label_left, color=color.new(#131722,5), textcolor=color.new(#F23645,55), size=size.small)
    label.new(bx, tp, "TP " + str.tostring(tp, "#.00"), style=label.style_label_left, color=color.new(#131722,5), textcolor=c_bear,                size=size.small)
    label.new(bar_index, sl * 1.0003,
         "▼ ALCHEMIST SHORT\n" +
         "━━━━━━━━━━━━━━━━━\n" +
         "Entry : " + str.tostring(e,  "#.00") + "\n" +
         "SL    : " + str.tostring(sl, "#.00") + "\n" +
         "1R    : " + str.tostring(r1, "#.00") + "\n" +
         "TP    : " + str.tostring(tp, "#.00") + "\n" +
         "R:R   : 1:2 | ATR: " + str.tostring(math.round(h4_atr,2)),
         style=label.style_label_down, color=color.new(#131722,5),
         textcolor=c_bear, size=size.normal)

// ─────────────────────────────────────────────────────────────────────────────
//  DASHBOARD (optional)
// ─────────────────────────────────────────────────────────────────────────────
bias_txt   = bias == 1 ? "BULLISH ▲" : bias == -1 ? "BEARISH ▼" : "NEUTRAL ─"
bias_col   = bias == 1 ? c_bull : bias == -1 ? c_bear : c_neutral
h4_status  = bias == 1 ? h4_bull_ok : bias == -1 ? h4_bear_ok : false
sess_txt   = in_london ? "London ✅" : "Off-session"

var label dash_lbl = na
if show_dash
    label.delete(dash_lbl)
    dash_lbl := label.new(bar_index, high * 1.0002,
         "ALCHEMIST v6\n" +
         "━━━━━━━━━━━━━━━━━\n" +
         "Bias    : " + bias_txt + "\n" +
         "H4 Gate : " + (h4_status ? "✅ GO" : "⏳ wait") + "\n" +
         "  Stack : " + (bias==1 ? (h4_stack_bull?"✅":"✗") : (h4_stack_bear?"✅":"✗")) + "\n" +
         "  ADX   : " + str.tostring(math.round(h4_adx,1)) + (h4_adx_ok?" ✅":" ✗") + "\n" +
         "  RSI   : " + str.tostring(math.round(h4_rsi,1)) + "\n" +
         "  Ext   : " + (not_extended?"✅":"✗ overextended") + "\n" +
         "Session : " + sess_txt,
         style=label.style_label_lower_right,
         color=color.new(#131722, 5),
         textcolor=bias_col, size=size.normal)

// ─────────────────────────────────────────────────────────────────────────────
//  ALERTS
// ─────────────────────────────────────────────────────────────────────────────
alertcondition(long_sig,
     title="Alchemist v6 — LONG",
     message='{"alert":"LONG","strategy":"Alchemist_v6","symbol":"{{ticker}}","tf":"M15","entry":"{{close}}","session":"London","rr":"1:2"}')
alertcondition(short_sig,
     title="Alchemist v6 — SHORT",
     message='{"alert":"SHORT","strategy":"Alchemist_v6","symbol":"{{ticker}}","tf":"M15","entry":"{{close}}","session":"London","rr":"1:2"}')
alertcondition(long_sig or short_sig,
     title="Alchemist v6 — Signal",
     message='{"alert":"SIGNAL","strategy":"Alchemist_v6","symbol":"{{ticker}}","tf":"M15","entry":"{{close}}"}')
